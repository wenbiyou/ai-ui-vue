{
  "name": "ai-ui-vue",
  "version": "0.1.0",
  "description": "Vue3 AI 应用专用组件库，专注于流式对话、智能表单、Markdown 渲染等 AI 场景",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "register:components": "vitepress-rc --docsDir docs",
    "docs:dev": "npm run register:components && vitepress dev docs",
    "docs:build": "npm run register:components && vitepress build docs",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mjs --fix",
    "format": "prettier --write ."
  },
  "keywords": [
    "vue3",
    "ai",
    "chatgpt",
    "streaming",
    "markdown",
    "component-library"
  ],
  "author": "wenbiyou",
  "license": "MIT",
  "devDependencies": {
    "@types/jsdom": "^28.0.1",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.0",
    "jsdom": "^29.0.1",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitepress": "^1.0.0",
    "vitepress-theme-demoblock": "^3.1.3",
    "vitest": "^1.0.0",
    "vue": "^3.4.0",
    "vue-tsc": "^3.2.6"
  },
  "dependencies": {
    "highlight.js": "^11.9.0",
    "marked": "^12.0.0"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "main": "./dist/ai-ui-vue.es.js",
  "module": "./dist/ai-ui-vue.es.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/ai-ui-vue.es.js",
      "require": "./dist/ai-ui-vue.umd.js"
    },
    "./dist/style.css": {
      "style": "./dist/style.css"
    }
  }
}
